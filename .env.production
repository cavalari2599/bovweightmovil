# Host del API para el build del APK (modo producción de Vite).
# Apunta a la IP LAN de tu PC en la Wi-Fi. El celular y la PC deben estar
# en la MISMA red Wi-Fi. Si tu IP cambia, edita esta línea y vuelve a compilar.
#
# Ver tu IP:  ipconfig  ->  "Dirección IPv4" del adaptador Wi-Fi.
VITE_API_HOST=http://192.168.0.6:8000
